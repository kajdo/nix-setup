[global]
    ### Display ###
    monitor = 0
    follow = none

    ### Geometry ###
    width = 400
    height = (0, 200)
    origin = top-right
    offset = 10x10
    scale = 0
    notification_limit = 20

    ### Progress Bar ###
    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    progress_bar_corner_radius = 4

    ### Appearance ###
    transparency = 15
    separator_height = 1
    padding = 12
    horizontal_padding = 12
    text_icon_padding = 16
    frame_width = 2
    frame_color = "#89b4fa"
    corner_radius = 10
    gap_size = 8
    separator_color = frame
    sort = yes
    sticky_history = yes
    history_length = 20

    # Modern font stack - falls back gracefully
    font = "JetBrains Mono 11"
    line_height = 0
    markup = full
    format = "<span face='JetBrains Mono' weight='bold' size='larger'>%s</span>\n%b"
    alignment = left
    vertical_alignment = center

    # Behavior
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    # Icons
    enable_recursive_icon_lookup = true
    icon_theme = "Adwaita"
    min_icon_size = 48
    max_icon_size = 64
    icon_path = /usr/share/icons/Adwaita/48x48/status/:/usr/share/icons/Adwaita/48x48/devices/

    ### Mouse ###
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

    ### Layer & Stack ###
    layer = overlay
    force_xwayland = false

[volume]
    # Rule for volume notifications
    appname = "volume"
    origin = top-right
    offset = 10x10
    width = 300
    height = (0, 100)

[urgency_low]
    # Soft, subtle - low priority info
    background = "#1e1e2e"
    foreground = "#a6adc8"
    frame_color = "#45475a"
    timeout = 3
    highlight = "#cba6f7"

[urgency_normal]
    # Default - clean and readable
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#89b4fa"
    timeout = 5
    highlight = "#89dceb"

[urgency_critical]
    # Eye-catching but not aggressive
    background = "#311b92"
    foreground = "#ffffff"
    frame_color = "#f38ba8"
    timeout = 0
    highlight = "#eba0ac"

# App-specific rules for better categorization

[spotify]
    appname = Spotify
    format = "<b>Now Playing</b>\n%s\n%b"
    frame_color = "#1db954"

[slack]
    appname = Slack
    frame_color = "#e01e5a"

[discord]
    appname = Discord
    frame_color = "#5865F2"

